{
  "name": "typed-object-keys",
  "version": "0.1.0",
  "description": "A tiny typed wrapper around Object.keys for TypeScript.",
  "keywords": [
    "keys",
    "object",
    "object-keys",
    "typed-keys",
    "typescript"
  ],
  "homepage": "https://github.com/leonsilicon/typed-object-keys#readme",
  "bugs": {
    "url": "https://github.com/leonsilicon/typed-object-keys/issues"
  },
  "license": "MIT",
  "author": "Leon Si <leon@leonsilicon.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonsilicon/typed-object-keys.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
